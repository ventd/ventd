{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(go:*)",
      "Bash(gofmt:*)",
      "Bash(golangci-lint:*)",
      "Bash(go test:*)",
      "Bash(go build:*)",
      "Bash(go vet:*)",
      "Bash(go mod:*)",
      "Bash(go run:*)",
      "Bash(go tool:*)",
      "Bash(staticcheck:*)",
      "Bash(govulncheck:*)",
      "Bash(git:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh run:*)",
      "Bash(gh workflow:*)",
      "Bash(gh auth status)",
      "Bash(gh api:*)",
      "Bash(make:*)",
      "Bash(shellcheck:*)",
      "Bash(yamllint:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(cut:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(wc:*)",
      "Bash(tr:*)",
      "Bash(diff:*)",
      "Bash(cmp:*)",
      "Bash(tree:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(realpath:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(pwd)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(test:*)",
      "Bash(true)",
      "Bash(false)",
      "Bash(which:*)",
      "Bash(command:*)",
      "Bash(env)",
      "Bash(uname:*)",
      "Bash(date:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(touch:*)",
      "Bash(ln:*)",
      "Bash(chmod:*)",
      "Bash(tar:*)",
      "Bash(gzip:*)",
      "Bash(gunzip:*)",
      "Bash(zstd:*)",
      "Bash(unzstd:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(pip:*)",
      "Bash(uv:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(docker:*)",
      "Bash(podman:*)",
      "Read(//home/cc-runner/**)",
      "Read(//tmp/**)",
      "Read(//var/tmp/**)",
      "Write(//home/cc-runner/**)",
      "Write(//tmp/**)",
      "Write(//var/tmp/**)",
      "Write(.claude/**)",
      "Write(.github/**)",
      "Write(internal/**)",
      "Write(cmd/**)",
      "Write(tools/**)",
      "Write(deploy/**)",
      "Write(docs/**)",
      "Write(scripts/**)",
      "Write(packaging/**)",
      "Write(release-notes/**)",
      "Write(testutil/**)",
      "Write(validation/**)",
      "Write(CHANGELOG.md)",
      "Write(README.md)",
      "Write(Makefile)",
      "Write(go.mod)",
      "Write(go.sum)",
      "Write(config.example.yaml)",
      "Write(.goreleaser.yml)",
      "Write(.gitignore)",
      "Write(.gitattributes)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(doas:*)",
      "Bash(su:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf ~/*)",
      "Bash(:(){ :|:& };:)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(shred:*)",
      "Bash(chown:*)",
      "Bash(systemctl:*)",
      "Bash(journalctl:*)",
      "Bash(service:*)",
      "Bash(useradd:*)",
      "Bash(userdel:*)",
      "Bash(usermod:*)",
      "Bash(groupadd:*)",
      "Bash(groupdel:*)",
      "Bash(visudo:*)",
      "Bash(passwd:*)",
      "Bash(apt:*)",
      "Bash(apt-get:*)",
      "Bash(dnf:*)",
      "Bash(yum:*)",
      "Bash(pacman:*)",
      "Bash(apk:*)",
      "Bash(brew:*)",
      "Bash(snap:*)",
      "Bash(iptables:*)",
      "Bash(nft:*)",
      "Bash(ip link:*)",
      "Bash(ip addr:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard origin/main)",
      "Bash(git reset --hard main)",
      "Bash(git branch -D main)",
      "Bash(git push origin :main)",
      "Bash(git push --delete origin main)",
      "Bash(gh repo delete:*)",
      "Bash(gh pr merge:*)",
      "Write(//etc/**)",
      "Write(//usr/**)",
      "Write(//opt/**)",
      "Write(//var/log/**)",
      "Write(//root/**)",
      "Write(//boot/**)",
      "Write(//sys/**)",
      "Write(//proc/**)",
      "Write(//dev/**)",
      "Read(//etc/shadow)",
      "Read(//etc/sudoers)",
      "Read(//root/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-context.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-bad-commits.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/bash-firewall.sh"
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/limit-subagents.sh"
          }
        ]
      },
      {
        "matcher": "Read|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/secret-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/go-fmt.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/go-lint.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/systemd-verify.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/filter-go-test.sh"
          }
        ]
      }
    ]
  }
}
